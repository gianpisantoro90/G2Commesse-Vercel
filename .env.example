# G2 Ingegneria - Environment Variables
# Copy this file to .env and fill in your values for local development

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/g2_ingegneria

# AI Configuration (Optional - for fallback support)
# The application will use these as fallback if not configured in the UI
ANTHROPIC_API_KEY=sk-ant-api...your-key-here
# Alternative variable names supported:
# CLAUDE_API_KEY=sk-ant-api...your-key-here
# AI_API_KEY=sk-ant-api...your-key-here

# For DeepSeek (if using DeepSeek models)
# DEEPSEEK_API_KEY=sk-...your-deepseek-key-here

# Node Environment
NODE_ENV=local

# Port Configuration
PORT=5000

# Authentication (REQUIRED)
# CRITICAL: Use strong passwords (min 12 characters, mix of uppercase, lowercase, numbers, symbols)
# DO NOT commit actual credentials to git
AUTH_USERNAME=your_username_here
AUTH_PASSWORD=your_secure_password_min_12_chars

# Session Secret (REQUIRED)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be at least 32 characters long
SESSION_SECRET=your_generated_session_secret_32_chars_minimum

# Note: You can also configure AI keys directly in the web interface
# via Sistema -> AI instead of using environment variables