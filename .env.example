# G2 Gestione Commesse - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# DATABASE CONFIGURATION (Choose one)
# ===========================================

# Option 1: Turso (Recommended - FREE)
# Get your credentials at: https://turso.tech
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Option 2: PostgreSQL/Neon (if not using Turso)
# DATABASE_URL=postgresql://user:password@host:5432/database

# ===========================================
# REQUIRED
# ===========================================

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-32-character-minimum-secret-key

# ===========================================
# OPTIONAL - AI FEATURES
# ===========================================

# Anthropic API for AI features
ANTHROPIC_API_KEY=sk-ant-...

# DeepSeek API (alternative AI provider)
DEEPSEEK_API_KEY=sk-...

# ===========================================
# OPTIONAL - EMAIL INTEGRATION
# ===========================================

# IMAP email polling (for AI analysis of incoming emails)
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=your-email@example.com
EMAIL_IMAP_PASSWORD=your-email-password
EMAIL_CHECK_INTERVAL=14400000
# Sender address for outgoing emails
EMAIL_FROM=noreply@g2ingegneria.it

# SMTP for sending emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
# SMTP_SECURE=true  # Uncomment for port 465 (SSL)

# SendGrid (alternative to SMTP_PASSWORD)
# SENDGRID_API_KEY=SG....

# ===========================================
# OPTIONAL - ONEDRIVE INTEGRATION
# ===========================================

# Microsoft Graph API for OneDrive
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id

# ===========================================
# DEVELOPMENT
# ===========================================

# Set to 'development' for local dev, 'production' for deployment
NODE_ENV=development

# Port (default: 5000)
PORT=5000
