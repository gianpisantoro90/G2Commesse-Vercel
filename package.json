{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:vercel": "vite build && tsx scripts/build-api.ts",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check": "tsc",
    "db:push": "npx drizzle-kit push",
    "db:migrate-user": "tsx scripts/migrate-initial-user.ts",
    "db:migrate-turso": "tsx scripts/migrate-to-turso.ts",
    "turso:init": "tsx -e \"import('./server/db-turso.js').then(m => m.initializeDatabase())\"",
    "vercel:dev": "vercel dev",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
