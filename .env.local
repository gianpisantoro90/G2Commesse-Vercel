NODE_ENV=local

# IMPORTANT: Change these credentials after first setup
# Use strong password: min 12 chars, mix of upper/lower/numbers/symbols
# NOTE: Avoid special chars that need JSON escaping: ! \ " in passwords for API compatibility
AUTH_USERNAME=G2Ingegneria
AUTH_PASSWORD=Change_Me_2025!

# Session secret - Generated with crypto.randomBytes(32).toString('hex')
# CRITICAL: Generate your own with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=a7f3e9c2b8d1f4a6e3c9b7d2f8e4a1c6b9f5e2d7a3c8b4f1e6d9a2c5b8f3e7a1

# ===========================================
# EMAIL - IMAP (ricezione email per analisi AI)
# ===========================================
# Configura questi parametri per attivare il polling email
# Il sistema leggerà le email via IMAP e le analizzerà con AI
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=your-email@g2ingegneria.it
EMAIL_IMAP_PASSWORD=your-app-password
# Intervallo polling in ms (default: 14400000 = 4 ore)
# EMAIL_CHECK_INTERVAL=14400000

# ===========================================
# EMAIL - SMTP (invio email)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@g2ingegneria.it
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@g2ingegneria.it

# ===========================================
# AI - Provider per analisi email
# ===========================================
# Anthropic Claude (consigliato per analisi email)
ANTHROPIC_API_KEY=sk-ant-api03-...
# DeepSeek (alternativa)
# DEEPSEEK_API_KEY=sk-...